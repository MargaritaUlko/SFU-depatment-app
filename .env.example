# Database
DATABASE_URL=postgresql+asyncpg://dept_user:dept_pass@localhost:5432/department_db
POSTGRES_USER=dept_user
POSTGRES_PASSWORD=dept_pass
POSTGRES_DB=department_db

# JWT
SECRET_KEY=change-me-to-a-64-character-random-string-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# Files
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=20

# Schedule cache
SCHEDULE_CACHE_TTL=3600
SCHEDULE_CACHE_SIZE=512
